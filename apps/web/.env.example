NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_AUTH_MODE=disabled
NEXT_PUBLIC_ENABLE_PUBLIC_DEMO_CREDENTIALS=false
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=

# Required only when NEXT_PUBLIC_AUTH_MODE=firebase. These are public Firebase web-app values.
# NEXT_PUBLIC_FIREBASE_API_KEY=public_web_api_key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=venuesignal.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=venuesignal
# NEXT_PUBLIC_FIREBASE_APP_ID=public_web_app_id
