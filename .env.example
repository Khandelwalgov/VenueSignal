# Backend Configuration
PORT=8000
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_MODE=disabled
PERSISTENCE_BACKEND=memory
SQLITE_PATH=/tmp/venuesignal.db
AI_PROVIDER=local
RATE_LIMIT_REQUESTS=180
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BYTES=300000
TRUST_PROXY_HEADERS=false
ALLOW_DEMO_RESET=true

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_AUTH_MODE=disabled

# Optional credential-backed adapters; local defaults above remain fully offline.
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# FIREBASE_PROJECT_ID=your_firebase_project_id_here
# NEXT_PUBLIC_FIREBASE_API_KEY=public_web_api_key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=project-id
# NEXT_PUBLIC_FIREBASE_APP_ID=public_web_app_id
