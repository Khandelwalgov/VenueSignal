ENVIRONMENT=production
PORT=8080
CORS_ALLOWED_ORIGINS=https://venuesignal.example
AUTH_MODE=firebase
PERSISTENCE_BACKEND=firestore
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
FIREBASE_PROJECT_ID=replace-with-google-cloud-project
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BYTES=300000
TRUST_PROXY_HEADERS=true
ALLOW_DEMO_RESET=false

# Supply GEMINI_API_KEY through Secret Manager, never this file.
# Use Application Default Credentials for Firebase Admin and Firestore.

NEXT_PUBLIC_API_BASE_URL=https://api.example/api
NEXT_PUBLIC_AUTH_MODE=firebase
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-public-web-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-with-project
NEXT_PUBLIC_FIREBASE_APP_ID=replace-with-public-app-id
