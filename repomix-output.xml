router = APIRouter()
MAX_UPLOAD_BYTES = 200_000
MAX_IMPORT_ROWS = 50


def _service(request: Request) -> WorkflowService:
    return request.app.state.workflow_service


@router.get("/reports", response_model=list[Report], summary="List evaluator reports")
