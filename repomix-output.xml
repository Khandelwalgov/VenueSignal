      startNodeId: "N_L0_W_ACC_ENT",
      destinationNodeId: "N_L2_SEC_209_218",
      constraints: { stepFree: true, includeStaffOnly: false },
    }),
  });
}

export function createReport(rawText: string): Promise<VenueReport> {
