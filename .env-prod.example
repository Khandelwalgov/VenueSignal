# Render backend production variables. Do not upload this file itself.
ENVIRONMENT=production
AUTH_MODE=firebase
PERSISTENCE_BACKEND=firestore
FIREBASE_PROJECT_ID=venuesignal
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/firebase-service-account.json
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=PASTE_IN_RENDER_SECRET_ENVIRONMENT_ONLY
CORS_ALLOWED_ORIGINS=https://venuesignal.vercel.app
TRUST_PROXY_HEADERS=true
ALLOW_DEMO_RESET=false
RATE_LIMIT_REQUESTS=180
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BYTES=300000

# Render supplies PORT automatically. Do not set Firebase web values here.
